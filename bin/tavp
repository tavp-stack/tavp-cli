#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoloaders = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../../autoload.php',
];

$loaded = false;
foreach ($autoloaders as $autoloader) {
    if (file_exists($autoloader)) {
        require_once $autoloader;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Error: Composer autoloader not found. Run 'composer install' first." . PHP_EOL);
    exit(1);
}

use Tavp\Cli\TavpCommand;

$command = new TavpCommand();
$command->run($argv);
