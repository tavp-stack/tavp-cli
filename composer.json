{
    "name": "tavp/cli",
    "description": "The official TAVP command line tool — scaffolding, migrations, auth, deploy and more.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/console": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tavp\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tavp\\Cli\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/tavp"],
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
